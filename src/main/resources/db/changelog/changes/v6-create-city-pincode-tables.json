{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "create-city-table",
        "author": "admin",
        "changes": [
          {
            "createTable": {
              "tableName": "city",
              "columns": [
                {
                  "column": {
                    "name": "city_id",
                    "type": "BIGINT",
                    "autoIncrement": true,
                    "constraints": {
                      "primaryKey": true,
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "city_name",
                    "type": "VARCHAR(100)",
                    "constraints": {
                      "nullable": false,
                      "unique": true
                    }
                  }
                },
                {
                  "column": {
                    "name": "state",
                    "type": "VARCHAR(100)",
                    "constraints": {
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "is_active",
                    "type": "BOOLEAN",
                    "defaultValueBoolean": true,
                    "constraints": {
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "created_at",
                    "type": "TIMESTAMP WITHOUT TIME ZONE",
                    "defaultValueComputed": "CURRENT_TIMESTAMP",
                    "constraints": {
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "updated_at",
                    "type": "TIMESTAMP WITHOUT TIME ZONE",
                    "defaultValueComputed": "CURRENT_TIMESTAMP",
                    "constraints": {
                      "nullable": false
                    }
                  }
                }
              ]
            }
          }
        ]
      }
    },
    {
      "changeSet": {
        "id": "create-pincode-table",
        "author": "admin",
        "changes": [
          {
            "createTable": {
              "tableName": "pincode",
              "columns": [
                {
                  "column": {
                    "name": "pincode_id",
                    "type": "BIGINT",
                    "autoIncrement": true,
                    "constraints": {
                      "primaryKey": true,
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "pincode",
                    "type": "VARCHAR(10)",
                    "constraints": {
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "area_name",
                    "type": "VARCHAR(200)"
                  }
                },
                {
                  "column": {
                    "name": "city_id",
                    "type": "BIGINT",
                    "constraints": {
                      "nullable": false,
                      "foreignKeyName": "fk_pincode_city",
                      "references": "city(city_id)",
                      "deleteCascade": true
                    }
                  }
                },
                {
                  "column": {
                    "name": "is_active",
                    "type": "BOOLEAN",
                    "defaultValueBoolean": true,
                    "constraints": {
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "created_at",
                    "type": "TIMESTAMP WITHOUT TIME ZONE",
                    "defaultValueComputed": "CURRENT_TIMESTAMP",
                    "constraints": {
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "updated_at",
                    "type": "TIMESTAMP WITHOUT TIME ZONE",
                    "defaultValueComputed": "CURRENT_TIMESTAMP",
                    "constraints": {
                      "nullable": false
                    }
                  }
                }
              ]
            }
          }
        ]
      }
    },
    {
      "changeSet": {
        "id": "add-unique-constraint-pincode-city",
        "author": "admin",
        "changes": [
          {
            "addUniqueConstraint": {
              "tableName": "pincode",
              "columnNames": "pincode, city_id",
              "constraintName": "uq_pincode_city"
            }
          }
        ]
      }
    },
    {
      "changeSet": {
        "id": "create-index-pincode-city",
        "author": "admin",
        "changes": [
          {
            "createIndex": {
              "tableName": "pincode",
              "indexName": "idx_pincode_city_id",
              "columns": [
                {
                  "column": {
                    "name": "city_id"
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}

